<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dataplatform.masterdata.interface_.mapper.ApiInterfaceMapper">

    <resultMap id="ApiInterfaceVO" type="com.dataplatform.masterdata.interface_.entity.ApiInterfaceVO">
        <id column="id" property="id"/>
        <result column="interfaceCode" property="interfaceCode"/>
        <result column="interfaceName" property="interfaceName"/>
        <result column="dataTypeId" property="dataTypeId"/>
        <result column="dataTypeName" property="dataTypeName"/>
        <result column="vendorId" property="vendorId"/>
        <result column="vendorName" property="vendorName"/>
        <result column="path" property="path"/>
        <result column="description" property="description"/>
        <result column="requestSchema" property="requestSchema"/>
        <result column="responseSchema" property="responseSchema"/>
        <result column="sort" property="sort"/>
        <result column="status" property="status"/>
        <result column="createdBy" property="createdBy"/>
        <result column="createdAt" property="createdAt"/>
        <result column="updatedBy" property="updatedBy"/>
        <result column="updatedAt" property="updatedAt"/>
    </resultMap>

    <select id="selectListWithNames" resultMap="ApiInterfaceVO">
        SELECT
            i.id,
            i.interface_code AS interfaceCode,
            i.interface_name AS interfaceName,
            i.data_type_id AS dataTypeId,
            i.vendor_id AS vendorId,
            i.path,
            i.description,
            i.request_schema AS requestSchema,
            i.response_schema AS responseSchema,
            i.sort,
            i.status,
            i.created_by AS createdBy,
            i.created_at AS createdAt,
            i.updated_by AS updatedBy,
            i.updated_at AS updatedAt,
            v.vendor_name AS vendorName,
            dt.data_type_name AS dataTypeName
        FROM api_interface i
        LEFT JOIN vendor_info v ON i.vendor_id = v.id
        LEFT JOIN data_type dt ON i.data_type_id = dt.id
        WHERE i.deleted = false
        <if test="vendorId != null">
            AND i.vendor_id = #{vendorId}
        </if>
        <if test="dataTypeId != null">
            AND i.data_type_id = #{dataTypeId}
        </if>
        <if test="status != null and status != ''">
            AND i.status = #{status}
        </if>
        ORDER BY i.sort ASC, i.created_at DESC
    </select>

</mapper>
