        <sqlFile path="../migrations/V022__add_billing_operation_permissions.sql" relativeToChangelogFile="true" splitStatements="false" stripComments="false"/>
        <sqlFile path="../migrations/V024__seed_uapi_billing_plan.sql" relativeToChangelogFile="true" splitStatements="false" stripComments="false"/>

        <rollback>
            <sqlFile path="../rollbacks/U000__drop_baseline.sql" relativeToChangelogFile="true" splitStatements="false" stripComments="false"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
