<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <!--
      The SQL files below describe the repository's schema as of 2026-07-22.
      They intentionally form one baseline changeset because init.sql already
      contains parts of the historical incremental schema. New changes must be
      added as separate changesets with an explicit rollback block.
    -->
    <changeSet id="baseline-2026-07-22" author="data-platform" runInTransaction="true">
        <preConditions onFail="HALT" onError="HALT">
            <dbms type="postgresql"/>
        </preConditions>

        <!-- PostgreSQL dollar-quoted functions/DO blocks require whole-file execution. -->
        <sqlFile path="../init.sql" relativeToChangelogFile="true" splitStatements="false" stripComments="false"/>
        <sqlFile path="../migrations/V001__add_data_type_code.sql" relativeToChangelogFile="true" splitStatements="false" stripComments="false"/>
        <sqlFile path="../migrations/V002__create_api_interface.sql" relativeToChangelogFile="true" splitStatements="false" stripComments="false"/>
        <sqlFile path="../migrations/V003__add_billing_and_vendor_fields.sql" relativeToChangelogFile="true" splitStatements="false" stripComments="false"/>
        <sqlFile path="../migrations/V005__add_auth_config.sql" relativeToChangelogFile="true" splitStatements="false" stripComments="false"/>
        <sqlFile path="../migrations/V006__add_vendor_id_to_interface.sql" relativeToChangelogFile="true" splitStatements="false" stripComments="false"/>
        <sqlFile path="../migrations/V007__add_permission_tables.sql" relativeToChangelogFile="true" splitStatements="false" stripComments="false"/>
        <sqlFile path="../migrations/V007__create_interface_param.sql" relativeToChangelogFile="true" splitStatements="false" stripComments="false"/>
