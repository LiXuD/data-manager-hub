# SkyWalking Agent 配置 - 数据管理平台

# 服务名（每个服务启动时通过 -D 覆盖）
agent.service_name=${SW_AGENT_NAME:data-platform}

# OAP 后端地址
collector.backend_service=${SW_OAP_ADDRESS:127.0.0.1:11800}

# 采样率 (1-10000, 每 N 个请求采样 1 个)
agent.sample_n_per_3_secs=${SW_SAMPLE_RATE:10000}

# 开放遥测 (OpenTelemetry) 兼容
otel.enabled=false

# 日志级别
logging.level=${SW_LOG_LEVEL:INFO}

# 忽略的端点 (不追踪的路径)
trace.ignore_path=/actuator/**,/health/**

# Spring MVC 插件
plugin.springmvc.use_qualified_name_as_endpoint_name=true

# 跨进程传播协议头
plugin.toolkit.use_qualified_name_as_operation_name=true
